# Discord application credentials
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Production URLs, without trailing slashes
# FRONTEND_BASE_URL is the Vercel production URL or custom domain.
# BACKEND_BASE_URL is the Railway public service URL.
FRONTEND_BASE_URL=https://moderationdesk.example.com
BACKEND_BASE_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app

# Railway injects PORT automatically. Local default is 3001.
PORT=3001

# Use different random values with at least 32 characters
SESSION_SECRET=
PREMIUM_ADMIN_KEY=

# Optional comma-separated origins for direct API access.
# Normal browser traffic should use the Vercel /api proxy.
ALLOWED_ORIGINS=http://localhost:3000

# Optional comma-separated guild IDs for Pro+ access during development
ENTERPRISE_GUILD_IDS=

# Discord command registration
REGISTER_COMMANDS_ON_START=false
DEV_GUILD_ID=

# Railway volumes are detected automatically through RAILWAY_VOLUME_MOUNT_PATH.
# For local development only:
DATA_DIR=./data
LOG_LEVEL=info

# Discord guild subscription SKUs. Create these in Discord Developer Portal → Monetization → Manage SKUs.
# The application uses entitlement events and entitlement checks as the access source of truth.
DISCORD_PRO_SKU_ID=
DISCORD_PRO_PLUS_SKU_ID=

# Legacy optional Stripe integration. Leave blank when using Discord billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Optional public links
PRIVACY_URL=
TERMS_URL=
SUPPORT_URL=

{
  "name": "moderationdesk",
  "version": "1.2.0",
  "description": "Railway-hosted Discord bot and API for the ModerationDesk platform.",
  "type": "module",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node src/deployCommands.js",
    "check": "node scripts/validate.js",
    "test": "node --test",
    "verify": "npm run check && npm test"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "express": "^4.21.2"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
